{
  "expo": {
    "name": "Build Your Target Body",
    "slug": "build-your-target-body",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#8b5cf6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.buildyourtargetbody.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for progress photo uploads.",
        "NSPhotoLibraryUsageDescription": "Used for selecting progress photos.",
        "NSFaceIDUsageDescription": "Used for biometric login.",
        "NSHealthShareUsageDescription": "Read steps, distance, and workouts to reduce manual data entry.",
        "NSHealthUpdateUsageDescription": "Write workout data back to Apple Health."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#8b5cf6"
      },
      "package": "com.buildyourtargetbody.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_EXERCISE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "color": "#8b5cf6",
          "androidMode": "default",
          "androidCollapsedTitle": "Build Your Target Body"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Used for selecting progress photos.",
          "cameraPermission": "Used for taking progress photos."
        }
      ]
    ],
    "scheme": "buildyourtargetbody",
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}

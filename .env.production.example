# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_strong_random_password
POSTGRES_DB=buildyourbody

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:CHANGE_THIS_strong_random_password@db:5432/buildyourbody

# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_64_char_random_secret_minimum_32_chars

GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated allowed origins (no trailing slash)
CORS_ORIGINS=https://yourdomain.com

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
SHOW_DOCS=false

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# Leave empty to disable error tracking
SENTRY_DSN=

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://yourdomain.com
